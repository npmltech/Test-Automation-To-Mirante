            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert - Messagem de confirmacao de compra" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">String actualValue = vars.get(&quot;CONFIRMATION_MESSAGE&quot;);
String expectedValue = &quot;Thank you for your purchase today!&quot;;

if (actualValue == null || actualValue.length() &lt; 1) {
	AssertionResult.setFailure(true); 
	AssertionResult.setFailureMessage(&quot;A mensagem de compra da passagem nao apareceu.&quot;);
} else if (!actualValue.equals(expectedValue)) {
    AssertionResult.setFailure(true);
    AssertionResult.setFailureMessage(&quot;Valor esperado: [&quot; + expectedValue + &quot;] mas foi encontrado: [&quot; + actualValue + &quot;].&quot;);
} else {
	AssertionResult.setFailure(false);
	log.info(&quot;Passou: A mensagem [&quot; + actualValue + &quot;] esta correta!&quot;);
}</stringProp>
              <stringProp name="scriptLanguage">java</stringProp>
            </JSR223Assertion>
            <hashTree/>
            <BoundaryExtractor guiclass="BoundaryExtractorGui" testclass="BoundaryExtractor" testname="Extraindo mensagem de confirmacao" enabled="true">
              <stringProp name="BoundaryExtractor.useHeaders">as_document</stringProp>
              <stringProp name="BoundaryExtractor.refname">CONFIRMATION_MESSAGE</stringProp>
              <stringProp name="BoundaryExtractor.lboundary">&lt;div class=&quot;container hero-unit&quot;&gt;         &lt;h1&gt;</stringProp>
              <stringProp name="BoundaryExtractor.rboundary">&lt;/h1&gt;</stringProp>
              <stringProp name="BoundaryExtractor.default">Thank you for your purchase today!</stringProp>
              <boolProp name="BoundaryExtractor.default_empty_value">false</boolProp>
              <stringProp name="BoundaryExtractor.match_number">1</stringProp>
            </BoundaryExtractor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Validando mensagem de confirmacao de compra" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">String actualValue = vars.get(&quot;CONFIRMATION_MESSAGE&quot;);
String expectedValue = &quot;Thank you for your purchase today!&quot;;

if (actualValue == null || actualValue.length() &lt; 1) {
	prev.setSuccessful(false);
	prev.setResponseMessage(&quot;A mensagem de compra da passagem nao apareceu.&quot;);
} else if (!actualValue.equals(expectedValue)) {
	prev.setSuccessful(false);
	prev.setResponseMessage(&quot;Valor esperado: [&quot; + expectedValue + &quot;] mas foi encontrado: [&quot; + actualValue + &quot;].&quot;);
} else {
	prev.setSuccessful(true);
	log.info(&quot;Passou: A mensagem [&quot; + actualValue + &quot;] esta correta!&quot;);
}
</stringProp>
              <stringProp name="scriptLanguage">java</stringProp>
            </JSR223PostProcessor>
