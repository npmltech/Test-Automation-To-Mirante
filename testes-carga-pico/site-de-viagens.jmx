<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Plano de testes para o site de viagens e compra de passagens">
      <stringProp name="TestPlan.comments">Plano otimizado para o desafio tecnico: carga e pico no mesmo JMX, sem recursos estaticos.</stringProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="BASE_URL" elementType="Argument">
            <stringProp name="Argument.name">BASE_URL</stringProp>
            <stringProp name="Argument.value">${__P(baseUrl,www.blazedemo.com)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="LOAD_THREADS" elementType="Argument">
            <stringProp name="Argument.name">LOAD_THREADS</stringProp>
            <stringProp name="Argument.value">${__P(loadThreads,700)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="LOAD_RAMP_UP" elementType="Argument">
            <stringProp name="Argument.name">LOAD_RAMP_UP</stringProp>
            <stringProp name="Argument.value">${__P(loadRampUp,120)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="LOAD_DURATION" elementType="Argument">
            <stringProp name="Argument.name">LOAD_DURATION</stringProp>
            <stringProp name="Argument.value">${__P(loadDuration,300)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="SPIKE_THREADS" elementType="Argument">
            <stringProp name="Argument.name">SPIKE_THREADS</stringProp>
            <stringProp name="Argument.value">${__P(spikeThreads,0)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="SPIKE_RAMP_UP" elementType="Argument">
            <stringProp name="Argument.name">SPIKE_RAMP_UP</stringProp>
            <stringProp name="Argument.value">${__P(spikeRampUp,10)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="SPIKE_DELAY" elementType="Argument">
            <stringProp name="Argument.name">SPIKE_DELAY</stringProp>
            <stringProp name="Argument.value">${__P(spikeDelay,120)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="SPIKE_DURATION" elementType="Argument">
            <stringProp name="Argument.name">SPIKE_DURATION</stringProp>
            <stringProp name="Argument.value">${__P(spikeDuration,60)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>
